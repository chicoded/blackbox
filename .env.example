# ---- server (server/) ----
# Port the Socket.IO server listens on. Render/Railway set this automatically.
PORT=3001

# ---- client (client/) ----
# URL of the deployed Socket.IO server. Set this in Vercel project env vars.
# Locally you can leave it blank — the client falls back to http://<host>:3001.
# VITE_SERVER_URL=https://blackbox-server.onrender.com
